output "Samsung Electric Company SAMSUNG Unknown" {
    mode 1920x1080@60
    position 0,0
    scale 1.0
    alias $TV
}

output "Samsung Electric Company S24F350 H4ZN911731" {
    mode 1920x1080@71.910
    position 0,0
    scale 1.0
    adaptive_sync on
    alias $MONITOR_SAMSUNG
}

output "Thermotrex Corporation TL156MDMP31-0 Unknown" {
    mode 3200x2000@120
    position 0,1080
    scale 1.666666
    adaptive_sync on
    alias $INTERNAL
}

profile tv {
    output $TV enable
    output $INTERNAL disable
}

profile portable {
    output $INTERNAL enable position 0,0
}

profile huge_balls {
    output $MONITOR_SAMSUNG enable 
    output $INTERNAL enable
}